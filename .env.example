# Copy this to .env and fill in your OpenStack credentials
# Never commit .env to source control

OS_AUTH_URL=http://your-openstack-host:5000/v3
OS_USERNAME=admin
OS_PASSWORD=your-password
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne

APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
